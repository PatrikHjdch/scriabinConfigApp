<UserControl x:Class="scriabinWPF.NoteLinkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:scriabinWPF"
             mc:Ignorable="d"  d:DataContext="{d:DesignInstance Type=local:NoteLinkViewModel}"
             d:DesignHeight="78" d:DesignWidth="950">
    <UserControl.Resources>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Rectangle Grid.ColumnSpan="3" Grid.RowSpan="1" Stroke="White" StrokeThickness="1" Fill="#333333"/>
        <StackPanel x:Name="ContentHolder" Orientation="Horizontal" Grid.Column="0" Grid.Row="0">
            <Image x:Name="TypeIcon" Width="64" Margin="7 " Source="/assets/notelink.png"/>
            <StackPanel x:Name="MidiChannelHolder" Orientation="Vertical">
            <TextBlock Text="MIDI Channel" Foreground="White" Grid.Row="0" Grid.Column="1" Margin="8"/>
            <local:NumericUpDown x:Name="MidiChannelUpDown" Width="100" Height="20"
                                 Grid.Row="1" Grid.Column="1" Margin="8" MinValue="1" MaxValue="16"
                                 Value="{Binding MidiChannel, Mode=TwoWay}"/>
            </StackPanel>
            <StackPanel x:Name="PitchHolder" Orientation="Vertical">
                <TextBlock Text="Pitch" Foreground="White" Grid.Column="2" Grid.Row="0" Margin="8"/>
                <local:NumericUpDown x:Name="PitchUpDown" Width="100" Height="20" Grid.Column="2" Grid.Row="1"
                                     Margin="8" MinValue="0" MaxValue="127"
                                     Value="{Binding Pitch, Mode=TwoWay}"/>
            </StackPanel>
            <Rectangle Width="1" Height="60" Fill="LightGray" Grid.Column="3" Grid.RowSpan="2" Margin="8"/>
            <StackPanel x:Name="DmxChannelHolder" Orientation="Vertical">
                <TextBlock Text="DMX Channel" Foreground="White" Grid.Column="4" Grid.Row="0" Margin="8"/>
                <local:NumericUpDown x:Name="DmxChannelUpDown" Width="100" Height="20"
                                     Grid.Column="4" Grid.Row="1" Margin="8" MinValue="1" MaxValue="512"
                                     Value="{Binding DmxChannel, Mode=TwoWay}"/>
            </StackPanel>
            <StackPanel x:Name="UseVelocityHolder" Orientation="Vertical">
                <TextBlock Text="Use Velocity" Foreground="White" Grid.Column="7" Grid.Row="0" Margin="8"/>
                <CheckBox x:Name="UseVelocityCheckBox" Foreground="White" Grid.Column="7" Grid.Row="0" Margin="8"
                          HorizontalAlignment="Center" IsChecked="{Binding UsesVelocity, Mode=TwoWay}"/>
            </StackPanel>
            <StackPanel x:Name="DmxValueOnHolder" Orientation="Vertical">
                <TextBlock Text="DMX On Value" Foreground="White" Grid.Column="5" Grid.Row="0" Margin="8"/>
                <local:NumericUpDown x:Name="DmxValueOnUpDown" Width="100" Height="20" Grid.Column="5" Grid.Row="1"
                                     Margin="8" MinValue="0" MaxValue="255" Value="{Binding DmxValueOn, Mode=TwoWay}"/>
            </StackPanel>
            <StackPanel x:Name="DmxValueOffHolder" Orientation="Vertical">
                <TextBlock Text="DMX Off Value" Foreground="White" Grid.Column="6" Grid.Row="0" Margin="8"/>
                <local:NumericUpDown x:Name="DmxValueOffUpDown" Width="100" Height="20"
                                     Grid.Column="6" Grid.Row="1" Margin="8"
                                     MinValue="0" MaxValue="255" Value="{Binding DmxValueOff, Mode=TwoWay}"/>
            </StackPanel>
            <StackPanel x:Name="TimeoutHolder" Orientation="Vertical">
                <StackPanel x:Name="TimeoutEnableHolder" Orientation="Horizontal">
                    <TextBlock Text="Timeout" Foreground="White" Grid.Column="8" Grid.Row="0" Margin="8"/>
                    <CheckBox x:Name="TimeoutEnableCheckBox" Foreground="White" Grid.Column="8" Grid.Row="0"
                              Margin="8" IsChecked="{Binding TimeoutEnabled, Mode=TwoWay}"/>
                </StackPanel>
                <local:NumericUpDown x:Name="TimeoutUpDown" Width="100" Height="20" Grid.Column="8"
                                     Grid.Row="1" Margin="8" MinValue="0" MaxValue="10000"
                                     Value="{Binding Timeout, Mode=TwoWay}"/>
            </StackPanel>
        </StackPanel>
        <Button Content="X" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" Grid.Column="2" Grid.Row="0" Click="DeleteLink_Click"/>
    </Grid>
</UserControl>
