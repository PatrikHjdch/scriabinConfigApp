    <Grid>
        <ScrollViewer x:Name="LinkScrollViewer" Grid.Column="0" Grid.Row="0">
            <StackPanel x:Name="LinkStackPanel" Margin="8" >
                <ItemsControl ItemsSource="{Binding Links}">
                    <ItemsControl.Resources>
                        <DataTemplate DataType="{x:Type local:NoteLinkModel}">
                            <local:NoteLinkView DeleteLinkClicked="OnDeleteLinkClicked" Padding="2"/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type local:NoteOnLinkModel}">
                            <local:NoteOnLinkView DeleteLinkClicked="OnDeleteLinkClicked" Padding="2"/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type local:NoteOffLinkModel}">
                            <local:NoteOffLinkView DeleteLinkClicked="OnDeleteLinkClicked" Padding="2"/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type local:ControlChangeLinkModel}">
                            <local:ControlChangeLinkView DeleteLinkClicked="OnDeleteLinkClicked" Padding="2"/>
                        </DataTemplate>
                    </ItemsControl.Resources>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:NoteLinkModel}">
                            <ContentControl Content="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Grid x:Name="AddLinkButtonHolder" >
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0">
                        <Button x:Name="AddNoteLinkButton" Style="{DynamicResource AddLinkButtonStyle}" Content="Add Note Link" Height="78" Width="150" Margin="4" Click="AddNoteLink_Click" Padding="2"/>
                        <Button x:Name="AddNoteOnLinkButton" Style="{DynamicResource AddLinkButtonStyle}" Content="Add Note On Link" Height="78" Width="150" Margin="4" Click="AddNoteOnLink_Click" Padding="2"/>
                        <Button x:Name="AddNoteOffLinkButton" Style="{DynamicResource AddLinkButtonStyle}" Content="Add Note Off Link" Height="78" Width="150" Margin="4" Click="AddNoteOffLink_Click" Padding="2"/>
                        <Button x:Name="AddControlChangeLinkButton" Style="{DynamicResource AddLinkButtonStyle}" Content="Add Control Change Link" Height="78" Width="150" Margin="4" Click="AddControlChangeLink_Click" Padding="2"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
